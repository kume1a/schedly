{
  "name": "@repo/db",
  "version": "0.0.0",
  "type": "module",
  "exports": {
    "./connection": {
      "types": "./src/connection.ts",
      "default": "./dist/connection.js"
    },
    "./schema": {
      "types": "./src/schema.ts",
      "default": "./dist/schema.js"
    },
    "./types": {
      "types": "./src/types.ts",
      "default": "./dist/types.js"
    },
    "./utils": {
      "types": "./src/utils.ts",
      "default": "./dist/utils.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .cache"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:^",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "catalog:"
  }
}
